meta {
  name: Get Komentar Artikel
  type: http
  seq: 8
}

get {
  url: {{base_url}}/artikel/:item_id/komentar
  body: none
  auth: none
}

params:query {
  page: 1
  per_page: 20
}

params:path {
  item_id: {{artikel_id}}
}

script:post-response {
  if (res.status === 200 && res.body.data && res.body.data.length > 0) {
    bru.setVar("komentar_id", res.body.data[0].id);
  }
}

